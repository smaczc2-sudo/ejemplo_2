namespace SistemaBiblioteca.Backend
{
    // Requerimiento: Uso de clases y objetos (Entidad Principal)
    public class Libro
    {
        // Requerimiento: Encapsulamiento y Propiedades
        public string Titulo { get; set; }
        public string Autor { get; set; }
        public string Editorial { get; set; }
        public int Anio { get; set; }
        
        // Regla de negocio: Controlar estado del libro
        public bool EstaPrestado { get; set; }

        // Constructor para inicializar el objeto Libro
        public Libro(string titulo, string autor, string editorial, int anio)
        {
            Titulo = titulo;
            Autor = autor;
            Editorial = editorial;
            Anio = anio;
            EstaPrestado = false; 
        }
    }
}
