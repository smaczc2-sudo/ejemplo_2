using System;

namespace SistemaBiblioteca.Backend
{
    [cite_start]// REQUERIMIENTO: Uso de clases y objetos para representar la entidad principal [cite: 78, 213]
    public class Libro
    {
        // REQUERIMIENTO: Encapsulamiento mediante el uso de propiedades { get; set; } [cite: 79, 80]
        [cite_start]// Estos atributos corresponden a la Variante 2: Sistema de Biblioteca [cite: 218]
        public string Titulo { get; set; }
        public string Autor { get; set; }
        public string Editorial { get; set; }
        public int Anio { get; set; }
        
        [cite_start]// REGLA DE NEGOCIO: Controlar si el ejemplar está disponible o prestado [cite: 228]
        public bool EstaPrestado { get; set; }

        // Constructor: Método especial para inicializar un nuevo objeto Libro
        public Libro(string titulo, string autor, string editorial, int anio)
        {
            Titulo = titulo;
            Autor = autor;
            Editorial = editorial;
            Anio = anio;
            [cite_start]// Al registrarse, el libro inicia por defecto como "Disponible" [cite: 211]
            EstaPrestado = false; 
        }
    }
}
